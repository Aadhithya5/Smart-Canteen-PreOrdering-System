<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <!-- ─────────────────────────────────────────────────────────
       Smart Canteen Pre-Ordering System — Servlet Mappings
       ───────────────────────────────────────────────────────── -->

  <display-name>SmartCanteenSystem</display-name>

  <!-- Default welcome file -->
  <welcome-file-list>
    <welcome-file>WebContent/pages/index.html</welcome-file>
    <welcome-file>pages/index.html</welcome-file>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>

  <!-- ── RegisterServlet ───────────────────────────────────── -->
  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <!-- ── LoginServlet ──────────────────────────────────────── -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <!-- ── MenuServlet ───────────────────────────────────────── -->
  <servlet>
    <servlet-name>MenuServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.MenuServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MenuServlet</servlet-name>
    <url-pattern>/menu</url-pattern>
  </servlet-mapping>

  <!-- ── CartServlet ───────────────────────────────────────── -->
  <servlet>
    <servlet-name>CartServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.CartServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/cart</url-pattern>
  </servlet-mapping>

  <!-- ── OrderServlet ──────────────────────────────────────── -->
  <servlet>
    <servlet-name>OrderServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.OrderServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>OrderServlet</servlet-name>
    <url-pattern>/order</url-pattern>
  </servlet-mapping>

  <!-- ── AdminMenuServlet ──────────────────────────────────── -->
  <servlet>
    <servlet-name>AdminMenuServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.AdminMenuServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminMenuServlet</servlet-name>
    <url-pattern>/adminMenu</url-pattern>
  </servlet-mapping>

  <!-- ── OrderStatusServlet ────────────────────────────────── -->
  <servlet>
    <servlet-name>OrderStatusServlet</servlet-name>
    <servlet-class>com.smartcanteen.servlet.OrderStatusServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>OrderStatusServlet</servlet-name>
    <url-pattern>/orderStatus</url-pattern>
  </servlet-mapping>

  <!-- ── Session timeout (30 minutes) ─────────────────────── -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

  <!-- ── Error pages ───────────────────────────────────────── -->
  <error-page>
    <error-code>404</error-code>
    <location>/WebContent/pages/index.html</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/WebContent/pages/index.html</location>
  </error-page>

</web-app>
